# Supabase
# Encontrados em: Project Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=sua_service_role_ou_anon_key_aqui

# Nome da tabela de contatos (padrão: contacts)
SUPABASE_TABLE=contacts

# Z-API 
# Encontrados no painel da sua instância em https://www.z-api.io
ZAPI_INSTANCE_ID=sua_instance_id
ZAPI_INSTANCE_TOKEN=seu_instance_token
ZAPI_CLIENT_TOKEN=seu_client_token_de_seguranca

# Configurações de envio
# Quantidade máxima de contatos que receberão a mensagem nesta execução
MAX_CONTATOS=3

# Template da mensagem. Use o marcador {nome_contato} para personalizar.
MENSAGEM_TEMPLATE=Olá {nome_contato}! Esta é uma mensagem automática de teste do desafio Python + Supabase + Z-API. 🚀
